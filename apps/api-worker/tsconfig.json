{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": false,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@ojekdes/shared-auth": ["../../packages/shared-auth/src/index.ts"],
      "@ojekdes/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@ojekdes/shared-constants": ["../../packages/shared-constants/src/index.ts"],
      "@ojekdes/shared-zod": ["../../packages/shared-zod/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
